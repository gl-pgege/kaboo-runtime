{
  "name": "@kaboo/runtime",
  "version": "0.1.0",
  "description": "A persistence plugin for the CopilotKit runtime: a custom AgentRunner + pluggable ThreadStore that persists the full AG-UI event log and replays it on reload. Framework-agnostic, no HTTP layer.",
  "author": "gl-pgege",
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gl-pgege/kaboo-runtime.git"
  },
  "homepage": "https://gl-pgege.github.io/@kaboo/runtime/",
  "bugs": {
    "url": "https://github.com/gl-pgege/@kaboo/runtime/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "copilotkit",
    "ag-ui",
    "agents",
    "kaboo",
    "persistence",
    "runtime"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "AGENTS.md",
    "llms.txt",
    "llms-full.txt",
    "!docs/**",
    "!examples/**",
    "!.mkdocs-venv/**"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc && node scripts/generate-inventory.mjs",
    "docs:llms": "node scripts/generate-llms.mjs",
    "docs:verify": "node scripts/verify-docs.mjs",
    "docs": "yarn docs:api && yarn docs:llms",
    "examples:typecheck": "node scripts/typecheck-examples.mjs",
    "prepack": "yarn build && yarn docs:api && yarn docs:llms && yarn docs:verify && yarn test"
  },
  "peerDependencies": {
    "@ag-ui/client": ">=0.0.57",
    "@copilotkit/runtime": ">=1.62.0",
    "pg": ">=8.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ag-ui/client": "^0.0.57",
    "@copilotkit/runtime": "^1.62.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "express": "^5.0.0",
    "pg": "^8.13.0",
    "rxjs": "7.8.1",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.8.3",
    "vitest": "^2"
  }
}
